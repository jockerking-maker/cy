        <mxCell id="error" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECF0F1;strokeColor=#E74C3C;fontColor=#E74C3C;fontSize=10;arcSize=8;" value="提示库存不足" vertex="1">
          <mxGeometry height="28" width="110" x="410" y="166" as="geometry" />
