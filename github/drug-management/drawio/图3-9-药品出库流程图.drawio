          <mxGeometry height="34" width="170" x="185" y="250" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#34495E;strokeColor=#2C3E50;fontColor=#ffffff;fontSize=11;arcSize=8;" value="检测预警，生成出库记录" vertex="1">
          <mxGeometry height="34" width="200" x="170" y="315" as="geometry" />
