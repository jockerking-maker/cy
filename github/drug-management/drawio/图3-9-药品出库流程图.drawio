        <mxCell id="e4" edge="1" parent="1" source="check" style="strokeColor=#2C3E50;strokeWidth=1.2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" target="error">
          <mxGeometry relative="1" as="geometry" />
