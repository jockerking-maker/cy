# ProjectFlow 环境变量

# 后端配置
PORT=3001
JWT_SECRET=projectflow_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
DB_PATH=./data/projectflow.db

# 数据库配置（生产环境使用 MySQL/PostgreSQL 时启用）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=password
# DB_NAME=projectflow

# 邮件配置
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@projectflow.com
MAIL_PASS=your_email_password
MAIL_FROM=ProjectFlow <noreply@projectflow.com>
MAIL_ENCRYPTION=tls

# 前端配置（仅构建时使用）
VITE_API_BASE_URL=http://localhost:3001/api/v1
